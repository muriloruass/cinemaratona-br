# Variáveis de ambiente para o CineMaratona BR
# Crie um arquivo .env copiando este exemplo:
#   cp .env.example .env
# e preencha com seus valores reais.
# NÃO commite o arquivo .env — ele está no .gitignore.

# API key do TMDB (gratuita em https://www.themoviedb.org/settings/api)
TMDB_API_KEY=sua_chave_aqui
